# =============================================================
# Twenty CRM — Environment Configuration
# Copy this file to .env and fill in all required values.
# NEVER commit .env to source control.
# =============================================================

# --- Image Version ---
# Pin to a specific release. Never use 'latest' in production.
# Check https://github.com/twentyhq/twenty/releases for latest.
TAG=v1.18.1

# --- Server ---
# Public URL used for CORS, email links, and OAuth callbacks.
# For Unraid LAN access: http://<unraid-ip>:8091
# For production with a domain: https://crm.yourdomain.com
SERVER_URL=http://UNRAID_IP:8092

# Host port Twenty is exposed on (maps to container port 3000)
TWENTY_PORT=8092

# --- Application Secret ---
# Generate with: openssl rand -base64 32
# Required. Change before first startup.
APP_SECRET=replace_with_random_secret

# --- Database ---
# No special characters in the password (avoids URL encoding issues).
# Generate with: openssl rand -hex 20
PG_DATABASE_NAME=twenty
PG_DATABASE_USER=twenty
PG_DATABASE_PASSWORD=replace_with_strong_password

# --- Optional: Email (SMTP) ---
# Required for password reset, notifications, and email sync features.
# EMAIL_DRIVER=smtp
# EMAIL_FROM_ADDRESS=crm@yourdomain.com
# EMAIL_FROM_NAME=Twenty CRM
# EMAIL_SYSTEM_ADDRESS=system@yourdomain.com
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# --- Optional: Google OAuth & Gmail/Calendar Sync ---
# Requires a Google Cloud project with OAuth 2.0 credentials.
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_CALLBACK_URL=${SERVER_URL}/auth/google/redirect
# AUTH_GOOGLE_APIS_CALLBACK_URL=${SERVER_URL}/auth/google-apis/get-access-token
# MESSAGING_PROVIDER_GMAIL_ENABLED=true
# CALENDAR_PROVIDER_GOOGLE_ENABLED=true

# --- Optional: Microsoft OAuth & Outlook/Calendar Sync ---
# AUTH_MICROSOFT_ENABLED=true
# AUTH_MICROSOFT_CLIENT_ID=
# AUTH_MICROSOFT_CLIENT_SECRET=
# AUTH_MICROSOFT_CALLBACK_URL=${SERVER_URL}/auth/microsoft/redirect
# AUTH_MICROSOFT_APIS_CALLBACK_URL=${SERVER_URL}/auth/microsoft-apis/get-access-token
# MESSAGING_PROVIDER_MICROSOFT_ENABLED=true
# CALENDAR_PROVIDER_MICROSOFT_ENABLED=true

# --- Optional: S3-Compatible Storage ---
# Switch from local filesystem to object storage (e.g. MinIO, AWS S3).
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_NAME=twenty-crm
# STORAGE_S3_ENDPOINT=http://minio:9000
