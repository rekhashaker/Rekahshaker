{
  "dashboard": {
    "id": null,
    "uid": "homelab-cluster-overview",
    "title": "Homelab k3s Cluster Overview",
    "description": "Comprehensive overview of the homelab k3s cluster: health, resources, storage, workloads, and network.",
    "tags": ["homelab", "k3s", "kubernetes"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [

      {
        "type": "row",
        "title": "Cluster Health",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
        "collapsed": false
      },
      {
        "type": "stat",
        "title": "Nodes Ready",
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "red" },
                { "value": 3, "color": "green" }
              ]
            },
            "mappings": []
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "targets": [
          {
            "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
            "legendFormat": "Ready",
            "refId": "A"
          },
          {
            "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"false\"})",
            "legendFormat": "NotReady",
            "refId": "B"
          }
        ]
      },
      {
        "type": "table",
        "title": "Node Status",
        "gridPos": { "h": 4, "w": 8, "x": 4, "y": 1 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {},
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Ready" },
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": { "type": "color-text" }
                },
                {
                  "id": "mappings",
                  "value": [
                    { "type": "value", "options": { "1": { "text": "Ready", "color": "green" } } },
                    { "type": "value", "options": { "0": { "text": "NotReady", "color": "red" } } }
                  ]
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "footer": { "enablePagination": false }
        },
        "transformations": [
          { "id": "labelsToFields", "options": {} },
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "__name__": true, "condition": true, "status": true, "job": true, "instance": true, "uid": true },
              "renameByName": { "node": "Node", "Value": "Ready" }
            }
          }
        ],
        "targets": [
          {
            "expr": "kube_node_status_condition{condition=\"Ready\",status=\"true\"}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ]
      },
      {
        "type": "stat",
        "title": "Running Pods / Total Pods",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "targets": [
          {
            "expr": "sum(kube_pod_status_phase{phase=\"Running\"})",
            "legendFormat": "Running",
            "refId": "A"
          },
          {
            "expr": "sum(kube_pod_info)",
            "legendFormat": "Total",
            "refId": "B"
          }
        ]
      },
      {
        "type": "gauge",
        "title": "API Server Availability (5m)",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "red" },
                { "value": 0.95, "color": "yellow" },
                { "value": 0.99, "color": "green" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] }
        },
        "targets": [
          {
            "expr": "avg_over_time(up{job=\"apiserver\"}[5m])",
            "legendFormat": "API Server",
            "refId": "A"
          }
        ]
      },

      {
        "type": "row",
        "title": "Resource Usage",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
        "collapsed": false
      },
      {
        "type": "gauge",
        "title": "Cluster CPU Usage",
        "gridPos": { "h": 6, "w": 4, "x": 0, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 0.7, "color": "yellow" },
                { "value": 0.9, "color": "red" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "showThresholdMarkers": true
        },
        "targets": [
          {
            "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
            "legendFormat": "CPU",
            "refId": "A"
          }
        ]
      },
      {
        "type": "gauge",
        "title": "Cluster RAM Usage",
        "gridPos": { "h": 6, "w": 4, "x": 4, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 0.7, "color": "yellow" },
                { "value": 0.9, "color": "red" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "showThresholdMarkers": true
        },
        "targets": [
          {
            "expr": "1 - (sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes))",
            "legendFormat": "RAM",
            "refId": "A"
          }
        ]
      },
      {
        "type": "gauge",
        "title": "Per-Node CPU Usage",
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 0.7, "color": "yellow" },
                { "value": 0.9, "color": "red" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "showThresholdMarkers": true,
          "orientation": "vertical"
        },
        "targets": [
          {
            "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
            "legendFormat": "{{ instance }}",
            "refId": "A"
          }
        ]
      },
      {
        "type": "gauge",
        "title": "Per-Node RAM Usage",
        "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 0.7, "color": "yellow" },
                { "value": 0.9, "color": "red" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "showThresholdMarkers": true,
          "orientation": "vertical"
        },
        "targets": [
          {
            "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
            "legendFormat": "{{ instance }}",
            "refId": "A"
          }
        ]
      },

      {
        "type": "row",
        "title": "Storage",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
        "collapsed": false
      },
      {
        "type": "stat",
        "title": "PVC Status",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 13 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" }
              ]
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Pending" },
              "properties": [
                { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
              ]
            },
            {
              "matcher": { "id": "byName", "options": "Lost" },
              "properties": [
                { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
              ]
            }
          ]
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "targets": [
          {
            "expr": "sum(kube_persistentvolumeclaim_status_phase{phase=\"Bound\"})",
            "legendFormat": "Bound",
            "refId": "A"
          },
          {
            "expr": "sum(kube_persistentvolumeclaim_status_phase{phase=\"Pending\"}) or vector(0)",
            "legendFormat": "Pending",
            "refId": "B"
          },
          {
            "expr": "sum(kube_persistentvolumeclaim_status_phase{phase=\"Lost\"}) or vector(0)",
            "legendFormat": "Lost",
            "refId": "C"
          }
        ]
      },
      {
        "type": "gauge",
        "title": "Unraid NFS Usage",
        "description": "Filesystem usage on NFS-mounted volumes from Unraid (10.200.0.2)",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 13 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 0.7, "color": "yellow" },
                { "value": 0.9, "color": "red" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "showThresholdMarkers": true
        },
        "targets": [
          {
            "expr": "1 - (avg(node_filesystem_avail_bytes{mountpoint=~\"/var/lib/kubelet/pods/.*/volumes/kubernetes.io~nfs/.*\",fstype=\"nfs4\"}) / avg(node_filesystem_size_bytes{mountpoint=~\"/var/lib/kubelet/pods/.*/volumes/kubernetes.io~nfs/.*\",fstype=\"nfs4\"}))",
            "legendFormat": "NFS Used",
            "refId": "A"
          }
        ]
      },
      {
        "type": "table",
        "title": "PVC Details",
        "gridPos": { "h": 4, "w": 12, "x": 12, "y": 13 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {},
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Phase" },
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": { "type": "color-text" }
                },
                {
                  "id": "mappings",
                  "value": [
                    { "type": "value", "options": { "Bound": { "text": "Bound", "color": "green" } } },
                    { "type": "value", "options": { "Pending": { "text": "Pending", "color": "yellow" } } },
                    { "type": "value", "options": { "Lost": { "text": "Lost", "color": "red" } } }
                  ]
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "sortBy": [{ "displayName": "Namespace" }],
          "footer": { "enablePagination": false }
        },
        "transformations": [
          { "id": "labelsToFields", "options": {} },
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "__name__": true, "Value": true, "job": true, "instance": true, "uid": true, "storageclass": true, "volumename": true },
              "renameByName": { "namespace": "Namespace", "persistentvolumeclaim": "PVC", "phase": "Phase" }
            }
          }
        ],
        "targets": [
          {
            "expr": "kube_persistentvolumeclaim_status_phase == 1",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ]
      },

      {
        "type": "row",
        "title": "Workloads",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
        "collapsed": false
      },
      {
        "type": "table",
        "title": "Deployment Status",
        "gridPos": { "h": 6, "w": 10, "x": 0, "y": 18 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {},
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Unavailable" },
              "properties": [
                {
                  "id": "custom.cellOptions",
                  "value": { "type": "color-text" }
                },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      { "value": null, "color": "green" },
                      { "value": 1, "color": "red" }
                    ]
                  }
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "sortBy": [{ "displayName": "Namespace" }],
          "footer": { "enablePagination": false }
        },
        "transformations": [
          {
            "id": "merge",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true },
              "renameByName": {}
            }
          }
        ],
        "targets": [
          {
            "expr": "kube_deployment_spec_replicas",
            "format": "table",
            "instant": true,
            "legendFormat": "",
            "refId": "A"
          },
          {
            "expr": "kube_deployment_status_replicas_available",
            "format": "table",
            "instant": true,
            "legendFormat": "",
            "refId": "B"
          },
          {
            "expr": "kube_deployment_status_replicas_unavailable",
            "format": "table",
            "instant": true,
            "legendFormat": "",
            "refId": "C"
          }
        ]
      },
      {
        "type": "table",
        "title": "Pod Restarts (24h)",
        "description": "Pods with restarts in the last 24 hours",
        "gridPos": { "h": 6, "w": 8, "x": 10, "y": 18 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "cellOptions": { "type": "color-text" }
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 1, "color": "yellow" },
                { "value": 5, "color": "red" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "showHeader": true,
          "sortBy": [{ "displayName": "Restarts", "desc": true }],
          "footer": { "enablePagination": false }
        },
        "transformations": [
          { "id": "labelsToFields", "options": {} },
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "uid": true, "container": true, "endpoint": true, "service": true, "image": true },
              "renameByName": { "namespace": "Namespace", "pod": "Pod", "Value": "Restarts" }
            }
          }
        ],
        "targets": [
          {
            "expr": "round(increase(kube_pod_container_status_restarts_total[24h])) > 0",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ]
      },
      {
        "type": "stat",
        "title": "Failed Pods",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 18 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 1, "color": "red" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "targets": [
          {
            "expr": "sum(kube_pod_status_phase{phase=\"Failed\"}) or vector(0)",
            "legendFormat": "Failed",
            "refId": "A"
          },
          {
            "expr": "sum(kube_pod_status_phase{phase=\"Pending\"}) or vector(0)",
            "legendFormat": "Pending",
            "refId": "B"
          },
          {
            "expr": "sum(kube_pod_status_phase{phase=\"Unknown\"}) or vector(0)",
            "legendFormat": "Unknown",
            "refId": "C"
          }
        ]
      },

      {
        "type": "row",
        "title": "Network",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
        "collapsed": false
      },
      {
        "type": "timeseries",
        "title": "Cluster Ingress / Egress Bandwidth",
        "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 15,
              "gradientMode": "scheme",
              "spanNulls": false,
              "axisBorderShow": false
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" }
              ]
            }
          },
          "overrides": [
            {
              "matcher": { "id": "byRegexp", "options": ".*Egress.*" },
              "properties": [
                { "id": "custom.transform", "value": "negative-Y" }
              ]
            }
          ]
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": { "displayMode": "list", "placement": "bottom" }
        },
        "targets": [
          {
            "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|cali.*|flannel.*|cni.*\"}[5m]))",
            "legendFormat": "Ingress (rx)",
            "refId": "A"
          },
          {
            "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|cali.*|flannel.*|cni.*\"}[5m]))",
            "legendFormat": "Egress (tx)",
            "refId": "B"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Per-Node Network I/O",
        "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 1,
              "fillOpacity": 10,
              "spanNulls": false,
              "axisBorderShow": false
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": { "displayMode": "list", "placement": "bottom" }
        },
        "targets": [
          {
            "expr": "sum by (instance) (rate(node_network_receive_bytes_total{device!~\"lo|veth.*|cali.*|flannel.*|cni.*\"}[5m]))",
            "legendFormat": "{{ instance }} rx",
            "refId": "A"
          },
          {
            "expr": "sum by (instance) (rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|cali.*|flannel.*|cni.*\"}[5m]))",
            "legendFormat": "{{ instance }} tx",
            "refId": "B"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
